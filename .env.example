# ==================================================
# dyia Environment Variables
# Copy this file to .env.local and fill in the values
# ==================================================

# ---- Clerk Authentication ----
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxxxx
CLERK_SECRET_KEY=sk_test_xxxxx
CLERK_WEBHOOK_SECRET=whsec_xxxxx

# Clerk redirect URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/app
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/app

# ---- Supabase Database ----
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ---- Stripe Payments ----
STRIPE_SECRET_KEY=sk_test_xxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxx
NEXT_PUBLIC_STRIPE_MONTHLY_PRICE_ID=price_xxxxx
NEXT_PUBLIC_STRIPE_ANNUAL_PRICE_ID=price_xxxxx
NEXT_PUBLIC_STRIPE_BASIC_MONTHLY_PRICE_ID=price_xxxxx
NEXT_PUBLIC_STRIPE_BASIC_ANNUAL_PRICE_ID=price_xxxxx
STRIPE_INTEL_PRICE_ID=price_xxxxx
# Optional: Founders coupon ID (auto-applied via /#pricing?founders=1)
# STRIPE_FOUNDERS_COUPON_ID=coupon_xxxxx

# ---- OpenAI (AI Assistant) ----
OPENAI_API_KEY=sk-xxxxx
# Optional: defaults to o4-mini-deep-research for Intel scans
# OPENAI_INTEL_MODEL=o4-mini-deep-research

# ---- Anthropic (Intel Action Plans) ----
# ANTHROPIC_API_KEY=sk-ant-xxxxx

# ---- App URL ----
# Set to your production URL. Vercel sets this automatically.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Email (Resend) ----
# Required for welcome emails, trial reminders, weekly insights, follow-up reminders
# RESEND_API_KEY=re_xxxxx
# RESEND_FROM_EMAIL=Dyia <hello@yourdomain.com>

# ---- Cron Jobs ----
# Required for scheduled tasks (trial reminders, weekly insights, follow-up reminders)
# Generate with: openssl rand -hex 32
# CRON_SECRET=your_random_hex_string

# ---- Pricing Calculator License ----
# License key for the standalone /pricing-calculator tool (Gumroad buyers)
CALCULATOR_LICENSE_KEY=your_license_key

# ---- Demo Mode (optional) ----
# Password for demo mode access. If not set, demo mode is disabled.
# DEMO_PASSWORD=your_demo_password

# ---- Mass Email OAuth (optional) ----
# Only needed if enabling the mass email blast feature
# GMAIL_CLIENT_ID=your_gmail_client_id
# GMAIL_CLIENT_SECRET=your_gmail_client_secret
# OUTLOOK_CLIENT_ID=your_outlook_client_id
# OUTLOOK_CLIENT_SECRET=your_outlook_client_secret

# ---- Error Monitoring (optional, recommended for production) ----
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx
# SENTRY_ORG=your_sentry_org
# SENTRY_PROJECT=your_sentry_project
# SENTRY_AUTH_TOKEN=sntrys_xxxxx
